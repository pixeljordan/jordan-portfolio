---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';

const projects = [
  {
    tag: "Research",
    title: "Hack for Good: Child Therapy Tools",
    description: "48-hour hackathon demonstrating Lean UX principles and Nielsen's heuristics to create impactful tools for child therapy professionals.",
    image: "/images/child-therapy.png",
    details: [
      "Designed a CDI Coding Counter for therapists to track behavioral observations in real-time during sessions",
      "Applied Nielsen's usability heuristics to ensure the interface was learnable within minutes",
      "Built for iPad — optimized for tap-heavy interaction during live therapy sessions",
      "Won recognition for balancing clinical accuracy with intuitive UX under extreme time pressure"
    ]
  },
  {
    tag: "Mobile",
    title: "PROOF: Shame-Aware EdTech Design",
    description: "A fraction comparison practice tool for high school students who are behind, shaped by behavioral science, learning research, and radical empathy.",
    details: [
      "Designed for students performing below grade level — the primary constraint was avoiding shame triggers",
      "Every interaction was reviewed through the lens of Carol Dweck's growth mindset research",
      "No scores, no leaderboards, no red X marks — progress is shown through mastery, not competition",
      "Prototype tested with educators specializing in math anxiety and learning differences"
    ]
  }
];
---

<Layout title="Additional Projects — Jordan Schonegg">
  <Navbar />
  <main class="pt-28 pb-24 px-6 md:px-10">
    <div class="max-w-4xl mx-auto">
      <!-- Back link -->
      <a href="/" class="inline-flex items-center gap-2 text-[var(--color-text-secondary)] text-sm font-medium mb-10 no-underline hover:text-[var(--color-text)] transition-colors group">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:-translate-x-1" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
        Back to Portfolio
      </a>

      <h1 class="font-display text-[clamp(2.2rem,5vw,3.2rem)] font-normal mb-3 reveal">Additional Projects</h1>
      <p class="text-lg text-[var(--color-text-secondary)] mb-16 reveal">
        Hackathons, passion projects, and explorations that shaped my design thinking.
      </p>

      <div class="space-y-20">
        {projects.map((project) => (
          <div class="reveal">
            <!-- Tag -->
            <span class="inline-block px-3 py-1 border border-[var(--color-border)] rounded-full text-[10px] font-semibold uppercase tracking-widest text-[var(--color-text-secondary)] mb-4">
              {project.tag}
            </span>

            <h2 class="font-display text-2xl md:text-3xl font-normal text-[var(--color-text)] mb-3 leading-snug">
              {project.title}
            </h2>

            <p class="text-[var(--color-text-secondary)] text-base leading-relaxed mb-6">
              {project.description}
            </p>

            <!-- Thumbnail -->
            {project.image ? (
              <div class="bg-[var(--color-bg-warm)] rounded-xl aspect-[16/10] flex items-center justify-center overflow-hidden border border-[var(--color-border)] p-6 mb-6">
                <img src={project.image} alt={project.title} class="w-full h-full object-contain rounded-md shadow-sm" loading="lazy" />
              </div>
            ) : (
              <div class="bg-[var(--color-text)] rounded-xl aspect-[16/10] flex flex-col items-center justify-center overflow-hidden p-8 text-center mb-6">
                <span class="font-display text-white/90 text-xl mb-2">{project.title.split(':')[0]}</span>
                <span class="text-white/40 text-xs font-medium uppercase tracking-widest">Prototype available</span>
              </div>
            )}

            <!-- Details -->
            <ul class="space-y-3">
              {project.details.map(detail => (
                <li class="flex gap-3 text-[var(--color-text-secondary)] text-sm leading-relaxed">
                  <span class="text-[var(--color-accent)] mt-1 flex-shrink-0">-</span>
                  {detail}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </main>
</Layout>
