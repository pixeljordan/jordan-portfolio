---
---
<section class="min-h-screen flex flex-col justify-center px-6 md:px-10 pt-24 pb-16 relative bg-[var(--color-bg)] overflow-hidden">
  <!-- Vivid pink/purple/peach gradient blob — large, saturated, matching Lovable -->
  <div class="absolute top-0 right-[-10%] w-[900px] h-[900px] pointer-events-none" style="background: radial-gradient(ellipse at 50% 50%, rgba(215,165,235,0.55) 0%, rgba(240,185,210,0.45) 20%, rgba(245,200,185,0.35) 40%, rgba(230,200,240,0.2) 55%, transparent 70%); filter: blur(40px);"></div>

  <div class="relative z-10 max-w-4xl">
    <!-- Title -->
    <h1 class="font-display text-[clamp(4.5rem,13vw,9rem)] font-medium tracking-[-0.025em] leading-[1] mb-8">
      <span class="hero-word" style="animation-delay: 0s">ux/ui </span>
      <span class="hero-word" style="animation-delay: 0.15s">designer</span>
    </h1>

    <!-- Description — slightly larger -->
    <p class="text-xl md:text-2xl text-[var(--color-text-secondary)] max-w-xl mb-12 hero-subtitle leading-relaxed">
      I design where the stakes are high and the systems are complex. Fintech, mortgage, AI-native products — built for the humans using them today and the agents navigating them tomorrow.
    </p>

    <!-- View Projects CTA -->
    <a href="#projects" class="inline-flex items-center gap-4 no-underline text-[var(--color-text)] font-semibold text-sm uppercase tracking-widest hero-description group">
      <span class="w-14 h-14 flex items-center justify-center rounded-full border border-[var(--color-text)] group-hover:bg-[var(--color-text)] group-hover:text-white transition-all duration-300">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </span>
      View Projects
    </a>

    <!-- Chat widget with real avatar -->
    <div class="mt-20 hero-tags">
      <button onclick="openChat()" class="inline-flex items-center gap-4 bg-white border border-[var(--color-border)] rounded-full px-5 py-3.5 shadow-sm w-full max-w-lg cursor-pointer hover:shadow-md hover:border-[var(--color-text-muted)] transition-all duration-300 text-left">
        <img src="/images/avatar-face.png" alt="Jordan Schonegg" class="w-11 h-11 rounded-full object-cover flex-shrink-0" />
        <span class="text-[var(--color-text-muted)] text-sm flex-1">Ask me anything about my experience...</span>
        <div class="w-10 h-10 rounded-full bg-[var(--color-text)] flex items-center justify-center flex-shrink-0 relative">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          <span class="absolute -top-0.5 -right-0.5 w-3 h-3 bg-[var(--color-accent)] rounded-full status-pulse"></span>
        </div>
      </button>
    </div>
  </div>
</section>
