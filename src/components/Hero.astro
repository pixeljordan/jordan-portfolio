---
---
<section class="min-h-screen flex flex-col justify-center px-6 md:px-12 pt-24 pb-16 relative bg-[var(--color-bg)] overflow-hidden">
  <!-- Pink/purple gradient blob -->
  <div class="absolute bottom-0 right-0 w-[700px] h-[500px] bg-[radial-gradient(ellipse_at_center,rgba(220,180,240,0.35),rgba(240,200,220,0.2),transparent_70%)] pointer-events-none blur-[40px]"></div>

  <div class="relative z-10 max-w-4xl">
    <!-- Title -->
    <h1 class="font-[var(--font-display)] text-[clamp(3.5rem,10vw,7rem)] font-normal tracking-tight leading-[0.95] mb-6">
      <span class="hero-word" style="animation-delay: 0s">ux/ui&nbsp;</span>
      <span class="hero-word" style="animation-delay: 0.15s">designer</span>
    </h1>

    <!-- Description -->
    <p class="text-lg md:text-xl text-[var(--color-text-secondary)] max-w-xl mb-10 hero-subtitle leading-relaxed">
      with a passion for making compliance feel human, turning chaos into clarity, and shipping fast without breaking trust.
    </p>

    <!-- View Projects CTA -->
    <a href="#projects" class="inline-flex items-center gap-3 no-underline text-[var(--color-text)] font-semibold text-sm uppercase tracking-widest hero-description group">
      <span class="w-12 h-12 flex items-center justify-center rounded-full border border-[var(--color-border)] group-hover:border-[var(--color-text)] transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </span>
      View Projects
    </a>

    <!-- Chat widget -->
    <div class="mt-10 hero-tags">
      <div class="inline-flex items-center gap-3 bg-white border border-[var(--color-border)] rounded-full px-4 py-3 shadow-sm max-w-md w-full">
        <div class="w-10 h-10 rounded-full bg-[var(--color-bg-warm)] flex items-center justify-center overflow-hidden flex-shrink-0">
          <div class="w-full h-full bg-gradient-to-br from-[#e8d5c4] to-[#d4b8a0] rounded-full"></div>
        </div>
        <span class="text-[var(--color-text-muted)] text-sm flex-1">Ask me anything about my experience...</span>
        <div class="w-9 h-9 rounded-full bg-[var(--color-text)] flex items-center justify-center flex-shrink-0 relative">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          <span class="absolute -top-0.5 -right-0.5 w-3 h-3 bg-[var(--color-accent)] rounded-full status-pulse"></span>
        </div>
      </div>
    </div>
  </div>
</section>
