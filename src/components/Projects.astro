---
const projects = [
  {
    tag: "AI Design",
    title: "AI-Powered Loan Review Platform",
    description: "Designed an AI-powered data validation platform that cut mortgage loan review time by 63%, serving 150+ daily active users with smart flagging and confidence scoring.",
    image: "/images/ai-loan-platform.png",
    device: "desktop",
    reverse: false
  },
  {
    tag: "Product",
    title: "Scaling for Growth: Multi-Tenant Order Management Platform",
    description: "A strategic product design case study showcasing rapid iteration, collaborative discovery, and scalable architecture that grew from 25-50 monthly orders to over 18,000.",
    image: "/images/order-management.png",
    device: "desktop",
    reverse: true
  },
  {
    tag: "Research",
    title: "Hack for Good: Child Therapy Tools",
    description: "48-hour hackathon demonstrating Lean UX principles and Nielsen's heuristics to create impactful tools for child therapy professionals.",
    image: "/images/child-therapy.png",
    device: "ipad",
    reverse: false
  },
  {
    tag: "Mobile",
    title: "PROOF: Shame-Aware EdTech Design",
    description: "A fraction comparison practice tool for high school students who are behind, shaped by behavioral science, learning research, and radical empathy.",
    device: "mobile",
    status: "Prototype available",
    reverse: true
  },
  {
    tag: "Conversational AI",
    title: "Invisible AI: Mortgage Prequalification That Feels Human",
    description: "Designed a conversational AI prequalification flow for a mortgage lender where users never realize they're talking to a bot. Built the retention strategy across a 5-day session arc, milestone system, and three white-label design systems.",
    device: "desktop",
    status: "Working prototype",
    reverse: false
  }
];
---
<section id="projects" class="py-24 px-6 md:px-10 bg-[var(--color-bg)]">
  <div class="max-w-6xl mx-auto">
    <span class="text-xs font-semibold uppercase tracking-widest text-[var(--color-accent)] mb-3 block reveal">Selected Work</span>
    <h2 class="font-display text-[clamp(2.2rem,5vw,3.2rem)] font-normal mb-3 heading-wipe">Work That Shipped</h2>
    <p class="text-lg text-[var(--color-text-secondary)] mb-16 reveal">
      Case studies from fintech, enterprise, and AI-powered products.
    </p>

    <div class="space-y-20">
      {projects.map((project, i) => (
        <div class={`reveal flex flex-col ${project.reverse ? 'md:flex-row-reverse' : 'md:flex-row'} md:items-center gap-8 md:gap-14`}>
          <!-- Thumbnail -->
          <div class="w-full md:w-[45%] flex-shrink-0">
            {project.image ? (
              <div class="bg-[var(--color-bg-warm)] rounded-xl aspect-[4/3] flex items-center justify-center overflow-hidden card-hover border border-[var(--color-border)] p-4">
                <img src={project.image} alt={project.title} class="w-full h-full object-contain rounded-md shadow-sm" loading="lazy" />
              </div>
            ) : (
              <div class="bg-[var(--color-text)] rounded-xl aspect-[4/3] flex flex-col items-center justify-center overflow-hidden card-hover p-8 text-center">
                <span class="font-display text-white/90 text-lg mb-2">{project.title.split(':')[0]}</span>
                <span class="text-white/40 text-xs font-medium uppercase tracking-widest">{project.status || 'Coming soon'}</span>
              </div>
            )}
          </div>
          <!-- Text -->
          <div class="flex-1">
            <div class="flex gap-3 items-center mb-4">
              <span class="font-display text-5xl font-medium text-[var(--color-accent)] leading-none opacity-20" aria-hidden="true">0{i + 1}</span>
              <span class="inline-block px-3 py-1 border border-[var(--color-border)] rounded-full text-[10px] font-semibold uppercase tracking-widest text-[var(--color-text-secondary)]">
                {project.tag}
              </span>
            </div>
            <h3 class="font-display text-xl md:text-2xl font-normal text-[var(--color-text)] mb-3 leading-snug">
              {project.title}
            </h3>
            <p class="text-[var(--color-text-secondary)] text-sm leading-relaxed mb-5">
              {project.description}
            </p>
            <span class="inline-flex items-center gap-2 text-[var(--color-text-muted)] text-xs font-medium uppercase tracking-widest">
              Case study available on request
            </span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
