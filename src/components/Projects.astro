---
const projects = [
  {
    tag: "AI-Powered Design",
    title: "AI-Powered Loan Review Platform",
    description: "Designed an AI-powered data validation platform that cut mortgage loan review time by 63%, serving 150+ daily active users with smart flagging and confidence scoring.",
    image: "/images/ai-loan-platform.png",
    device: "desktop",
    reverse: false
  },
  {
    tag: "Product Design",
    title: "Scaling for Growth: Multi-Tenant Order Management Platform",
    description: "A strategic product design case study showcasing rapid iteration, collaborative discovery, and scalable architecture that grew from 25-50 monthly orders to over 18,000.",
    image: "/images/order-management.png",
    device: "desktop",
    reverse: true
  },
  {
    tag: "UX Research",
    title: "Hack for Good: Child Therapy Tools",
    description: "48-hour hackathon demonstrating Lean UX principles and Nielsen's heuristics to create impactful tools for child therapy professionals.",
    image: "/images/child-therapy.png",
    device: "ipad",
    reverse: false
  },
  {
    tag: "Mobile Design",
    title: "PROOF: Shame-Aware EdTech Design",
    description: "A fraction comparison practice tool for high school students who are behind, shaped by behavioral science, learning research, and radical empathy.",
    device: "mobile",
    reverse: true
  }
];
---
<section id="projects" class="py-24 px-6 md:px-10 bg-[var(--color-bg)]">
  <div class="max-w-6xl mx-auto">
    <span class="text-xs font-semibold uppercase tracking-widest text-[var(--color-accent)] mb-3 block reveal">Selected Work</span>
    <h2 class="font-display text-[clamp(2.2rem,5vw,3.2rem)] font-normal mb-3 heading-wipe">Work That Shipped</h2>
    <p class="text-lg text-[var(--color-text-secondary)] mb-16 reveal">
      Case studies from fintech, enterprise, and AI-powered products.
    </p>

    <div class="space-y-24">
      {projects.map((project, i) => (
        <div class="reveal">
          <!-- Title above image -->
          <div class="mb-6">
            <div class="flex gap-4 mb-4">
              <span class="font-display text-5xl md:text-6xl font-normal text-[var(--color-border)] leading-none">0{i + 1}</span>
              <span class="inline-block px-4 py-1.5 border border-[var(--color-border)] rounded-full text-xs font-semibold uppercase tracking-widest text-[var(--color-text-secondary)] self-center translate-y-[4px]">
                {project.tag}
              </span>
            </div>
            <h3 class="font-display text-2xl md:text-3xl font-normal text-[var(--color-text)] mb-3 leading-snug">
              {project.title}
            </h3>
            <p class="text-[var(--color-text-secondary)] text-base leading-relaxed max-w-2xl">
              {project.description}
            </p>
          </div>
          <!-- Image -->
          <div class="mb-5">
            {project.image ? (
              <div class="bg-[var(--color-bg-warm)] rounded-2xl aspect-[16/10] flex items-center justify-center overflow-hidden card-hover border border-[var(--color-border)] p-6 md:p-10">
                <img src={project.image} alt={project.title} class="w-full h-full object-contain rounded-lg shadow-md" loading="lazy" />
              </div>
            ) : (
              <div class="bg-[var(--color-bg-warm)] rounded-2xl aspect-[16/10] flex items-center justify-center overflow-hidden card-hover border border-[var(--color-border)]">
                <div class="w-3/4 h-3/4 bg-white/60 rounded-xl shadow-sm border border-[var(--color-border)] flex items-center justify-center">
                  <span class="text-[var(--color-text-muted)] text-xs italic">Screenshot placeholder</span>
                </div>
              </div>
            )}
          </div>
          <!-- CTA -->
          <a href="#" class="link-arrow no-underline">
            View Case Study
            <span class="arrow">&rarr;</span>
          </a>
        </div>
      ))}
    </div>

    <div class="text-center mt-16 reveal">
      <a href="#" class="inline-flex items-center gap-2 text-[var(--color-text-secondary)] font-medium text-sm hover:text-[var(--color-text)] transition-colors no-underline group">
        View More Work
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    </div>
  </div>
</section>
