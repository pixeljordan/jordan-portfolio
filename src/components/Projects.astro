---
const projects = [
  {
    tag: "AI-Powered Design",
    title: "AI-Powered Loan Review Platform",
    description: "Designed an AI-powered data validation platform that cut mortgage loan review time by 63%, serving 150+ daily active users with smart flagging and confidence scoring.",
    reverse: false
  },
  {
    tag: "Product Design",
    title: "Scaling for Growth: Multi-Tenant Order Management Platform",
    description: "A strategic product design case study showcasing rapid iteration, collaborative discovery, and scalable architecture that grew from 25-50 monthly orders to over 18,000.",
    reverse: true
  },
  {
    tag: "UX Research",
    title: "Hack for Good: Child Therapy Tools",
    description: "48-hour hackathon demonstrating Lean UX principles and Nielsen's heuristics to create impactful tools for child therapy professionals.",
    reverse: false
  },
  {
    tag: "Mobile Design",
    title: "PROOF: Shame-Aware EdTech Design",
    description: "A fraction comparison practice tool for high school students who are behind, shaped by behavioral science, learning research, and radical empathy.",
    reverse: true
  }
];
---
<section id="projects" class="py-24 px-6 md:px-12 bg-[var(--color-bg)]">
  <div class="max-w-6xl mx-auto">
    <h2 class="font-[var(--font-display)] text-[clamp(2rem,4vw,3rem)] font-normal mb-3 heading-wipe">Selected Work</h2>
    <p class="text-lg text-[var(--color-text-secondary)] mb-16 reveal">
      Selected case studies from fintech, enterprise, and AI-powered products.
    </p>

    <div class="space-y-20">
      {projects.map((project) => (
        <div class={`reveal flex flex-col ${project.reverse ? 'md:flex-row-reverse' : 'md:flex-row'} gap-10 items-center`}>
          <!-- Image placeholder -->
          <div class="w-full md:w-1/2">
            <div class="bg-[var(--color-bg-warm)] rounded-2xl aspect-[4/3] flex items-center justify-center overflow-hidden card-hover border border-[var(--color-border)]">
              <div class="w-3/4 h-3/4 bg-white/60 rounded-xl shadow-sm border border-[var(--color-border)] flex items-center justify-center">
                <span class="text-[var(--color-text-muted)] text-xs italic">Screenshot placeholder</span>
              </div>
            </div>
          </div>
          <!-- Text -->
          <div class="w-full md:w-1/2">
            <span class="inline-block px-4 py-1.5 border border-[var(--color-border)] rounded-full text-xs font-semibold uppercase tracking-widest text-[var(--color-text-secondary)] mb-5">
              {project.tag}
            </span>
            <h3 class="font-[var(--font-display)] text-2xl md:text-3xl font-normal text-[var(--color-text-secondary)] mb-4 leading-snug">
              {project.title}
            </h3>
            <p class="text-[var(--color-text-secondary)] text-base leading-relaxed mb-6">
              {project.description}
            </p>
            <a href="#" class="inline-flex items-center gap-2 text-[var(--color-text)] font-medium text-sm hover:gap-3 transition-all no-underline group">
              View Case Study
              <span class="transition-transform group-hover:translate-x-1">&rarr;</span>
            </a>
          </div>
        </div>
      ))}
    </div>

    <div class="text-center mt-16 reveal">
      <a href="#" class="inline-flex items-center gap-2 text-[var(--color-text-secondary)] font-medium text-sm hover:text-[var(--color-text)] transition-colors no-underline">
        View More Work
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    </div>
  </div>
</section>
