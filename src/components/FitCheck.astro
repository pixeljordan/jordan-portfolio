---
const great = [
  "Fintech / mortgage industry",
  "Scaling 0→1 products",
  "Rapid iteration environments",
  "Cross-functional collaboration",
  "Complex B2B enterprise systems",
  "Teams valuing agent-first thinking"
];
const adapt = [
  "Enterprise with agile pockets",
  "Hybrid research/execution roles",
  "Established design systems needing evolution",
  "Remote-first or hybrid teams"
];
const notIdeal = [
  "Waterfall-only environments",
  "Purely visual/marketing design",
  "No user access or research budget",
  "Design as order-taking"
];
---
<section id="fit" class="py-24 px-6 md:px-12 bg-gradient-to-b from-[var(--color-bg-warm)] to-[var(--color-bg)]">
  <div class="max-w-6xl mx-auto text-center">
    <h2 class="font-[var(--font-display)] text-[clamp(2rem,4vw,3rem)] font-normal mb-3 heading-wipe">Is This a Good Fit?</h2>
    <p class="text-lg text-[var(--color-text-secondary)] mb-14 reveal">
      Transparent about where I excel and where I might not be the best match.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-left reveal">
      <!-- Great Fit -->
      <div class="stagger-item bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-2xl p-7 card-hover">
        <div class="flex items-center gap-2 mb-6">
          <span class="text-[var(--color-strong)] text-lg">✓</span>
          <h3 class="text-lg font-semibold">Great Fit</h3>
          <span class="text-[var(--color-strong)]">✓</span>
        </div>
        <ul class="space-y-3">
          {great.map(item => (
            <li class="flex gap-2.5 text-[0.95rem] text-[var(--color-text-secondary)]">
              <span class="text-[var(--color-strong)] mt-0.5">•</span>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <!-- Can Adapt -->
      <div class="stagger-item bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-2xl p-7 card-hover">
        <div class="flex items-center gap-2 mb-6">
          <span class="text-[var(--color-moderate)] text-lg">○</span>
          <h3 class="text-lg font-semibold">Can Adapt</h3>
          <span class="text-[var(--color-moderate)]">~</span>
        </div>
        <ul class="space-y-3">
          {adapt.map(item => (
            <li class="flex gap-2.5 text-[0.95rem] text-[var(--color-text-secondary)]">
              <span class="text-[var(--color-moderate)] mt-0.5">•</span>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <!-- Not Ideal -->
      <div class="stagger-item bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-2xl p-7 card-hover">
        <div class="flex items-center gap-2 mb-6">
          <span class="text-[var(--color-gaps)] text-lg">✗</span>
          <h3 class="text-lg font-semibold text-[var(--color-text-muted)]">Not Ideal</h3>
          <span class="text-[var(--color-gaps)]">✗</span>
        </div>
        <ul class="space-y-3">
          {notIdeal.map(item => (
            <li class="flex gap-2.5 text-[0.95rem] text-[var(--color-text-muted)]">
              <span class="text-[var(--color-gaps)] mt-0.5">•</span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
